; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but this file is kept in version control to track project settings.

config_version=5

[application]

config/name="microhorror"
config/description="Plataforma móvil de microexperiencias de terror en primera persona."
config/version="0.1.0"
run/main_scene="res://scenes/main_menu/main_menu.tscn"
config/features=PackedStringArray("4.5", "Mobile")
config/icon="res://assets/art/icon.svg"

[autoload]

GameState="*res://scripts/autoloads/game_state.gd"
BackendClient="*res://scripts/autoloads/backend_client.gd"
EventBus="*res://scripts/autoloads/event_bus.gd"
ContentCatalog="*res://scripts/autoloads/content_catalog.gd"
AnalyticsTracker="*res://scripts/autoloads/analytics_tracker.gd"
SceneManager="*res://scripts/autoloads/scene_manager.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/mode=4
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[physics]

common/physics_fps=60

[rendering]

renderer/rendering_method="mobile"
environment/defaults/default_clear_color=Color(0.05, 0.05, 0.05, 1)
